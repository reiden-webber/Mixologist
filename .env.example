# Copy to `.env` at the repository root. Used by Docker Compose, mixologist-cli (loads this file),
# and optional local tools.
ANTHROPIC_API_KEY=

# The CocktailDB API path key (segment after /v1/). Use 1 for the free public tier.
# Requests use: https://www.thecocktaildb.com/api/json/v1/[API KEY]/...
# Passed to the MCP server (e.g. via mixologist-cli or Compose).
COCKTAIL_DB_API_KEY=1

# mixologist-cli (optional)
# MCP_SERVER_PATH=
# MIXOLOGIST_HTTP_PORT=4100

# Local Next.js dev: optional. Defaults to http://127.0.0.1:4000 if unset.
# In Docker, compose sets BACKEND_URL on the web service to http://backend:4000
# BACKEND_URL=http://127.0.0.1:4000

# LangSmith (mixologist-cli only). Omit to disable tracing.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=bartender-mixologist
# Optional: EU or self-hosted API base URL
# LANGSMITH_ENDPOINT=

# LangChain tracer flush behavior (mixologist-cli):
# - For the HTTP server (`npm run dev:http` / start:http): prefer true so export I/O does not block responses.
# - For the interactive CLI (`npm run dev` / start): use false if you need traces flushed before the process exits.
# LANGCHAIN_CALLBACKS_BACKGROUND=true
